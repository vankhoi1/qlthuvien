@model QuanLyThuVien.Models.ReaderStatusViewModel
@{
    ViewData["Title"] = "Tình Trạng Mượn & Đặt Trước";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Đảm bảo bạn dùng đúng Layout
}

<style>
    .card-header-custom {
        background: linear-gradient(to right, #007bff, #0056b3);
        color: white;
    }

    .btn-action {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

    .badge-overdue {
        background-color: #dc3545 !important;
    }

    .badge-borrowing {
        background-color: #0d6efd !important;
    }

    .badge-pending {
        background-color: #ffc107 !important;
        color: #212529 !important;
    }
</style>

<div class="container py-4">
    <h2 class="mb-4">@ViewData["Title"]</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header card-header-custom">
            <h5 class="mb-0"><i class="bi bi-journal-check me-2"></i> Sách Đang Mượn</h5>
        </div>
        <div class="card-body">
            @if (Model.CurrentlyBorrowed.Any())
            {
                <div class="table-responsive">
                    <table id="currentlyBorrowedTable" class="table table-striped table-hover align-middle" style="width:100%">
                        <thead>
                            <tr>
                                <th>Tên Sách</th>
                                <th>Ngày Mượn</th>
                                <th>Hạn Trả</th>
                                <th class="text-center">Trạng Thái</th>
                                <th class="text-center">Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var loan in Model.CurrentlyBorrowed)
                            {
                                <tr>
                                    <td><a asp-controller="Account" asp-action="BookDetails" asp-route-bookId="@loan.BookId">@loan.Book.Title</a></td>

                                    <td>@loan.BorrowDate.ToString("dd/MM/yyyy")</td>
                                    <td>@(loan.DueDate.HasValue ? loan.DueDate.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                                    <td class="text-center">
                                        @if (loan.DueDate < DateTime.Now)
                                        {
                                            <span class="badge badge-overdue">Quá hạn</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-borrowing">Đang mượn</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!(loan.DueDate < DateTime.Now) && !loan.WasExtended)
                                        {
                                            <a asp-action="ExtendLoan" asp-route-loanId="@loan.LoanId" class="btn btn-info btn-sm btn-action disable-on-click">
                                                <i class="bi bi-calendar-plus"></i> Gia Hạn
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted fst-italic">Bạn không có sách nào đang mượn.</p>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header card-header-custom">
            <h5 class="mb-0"><i class="bi bi-calendar2-check-fill me-2"></i> Sách Đang Đặt Trước</h5>
        </div>
        <div class="card-body">
            @if (Model.PendingReservations.Any())
            {
                <div class="table-responsive">
                    <table id="pendingReservationsTable" class="table table-striped table-hover align-middle" style="width:100%">
                        <thead>
                            <tr>
                                <th>Tên Sách</th>
                                <th>Ngày Đặt</th>
                                <th class="text-center">Trạng Thái</th>
                                <th class="text-center">Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reservation in Model.PendingReservations)
                            {
                                <tr>
                                    <td><a asp-action="BookDetails" asp-route-bookId="@reservation.BookId">@reservation.Book?.Title</a></td>
                                    <td>@reservation.ReservationDate.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center"><span class="badge badge-pending">Đang chờ</span></td>
                                    <td class="text-center">
                                        <form asp-action="CancelReservation" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="reservationId" value="@reservation.ReservationId" />
                                            <button type="submit" class="btn btn-danger btn-sm btn-action" onclick="return confirm('Bạn có chắc muốn hủy yêu cầu đặt trước này?');">
                                                <i class="bi bi-x-lg"></i> Hủy
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted fst-italic">Bạn không có sách nào đang đặt trước.</p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Script cũ của bạn để vô hiệu hóa nút
            const buttons = document.querySelectorAll('.disable-on-click');
            buttons.forEach(function (button) {
                button.addEventListener('click', function (e) {
                    // ... (giữ nguyên logic cũ của bạn)
                });
            });

            // THÊM SCRIPT MỚI CHO DATATABLES
            const languageConfig = {
                sProcessing: "Đang xử lý...",
                sLengthMenu: "Xem _MENU_ mục",
                sZeroRecords: "Không tìm thấy dữ liệu phù hợp",
                sInfo: "Đang xem _START_ đến _END_ trong tổng số _TOTAL_ mục",
                sInfoEmpty: "Đang xem 0 đến 0 trong tổng số 0 mục",
                sInfoFiltered: "(được lọc từ _MAX_ mục)",
                sSearch: "Tìm kiếm:",
                oPaginate: { sFirst: "Đầu", sPrevious: "Trước", sNext: "Tiếp", sLast: "Cuối" }
            };

            $('#currentlyBorrowedTable').DataTable({
                language: languageConfig,
                "order": [[2, "asc"]], // Sắp xếp theo Hạn trả gần nhất
                "columnDefs": [
                    { "orderable": false, "targets": 4 } // Tắt sắp xếp cột Hành động
                ]
            });

            $('#pendingReservationsTable').DataTable({
                language: languageConfig,
                "order": [[1, "asc"]], // Sắp xếp theo Ngày đặt cũ nhất
                "columnDefs": [
                    { "orderable": false, "targets": 3 } // Tắt sắp xếp cột Hành động
                ]
            });
        });
    </script>
}