@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .stat-card {
        border-radius: 0.75rem;
        color: white;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

        .stat-card .stat-icon {
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 4.5rem;
            opacity: 0.3;
        }

    .stat-card-title {
        font-weight: 700;
        font-size: 1.2rem;
    }

    .stat-card-text {
        font-size: 0.9rem;
        opacity: 0.9;
    }

    .stat-card-footer {
        margin-top: 1.5rem;
        padding-top: 0.75rem;
        border-top: 1px solid rgba(255, 255, 255, 0.2);
    }

        .stat-card-footer a {
            color: white;
            text-decoration: none;
            font-weight: 600;
        }

            .stat-card-footer a:hover {
                text-decoration: underline;
            }

    /* Bảng màu cho từng card */
    .bg-gradient-staff {
        background: linear-gradient(to right, #4e54c8, #8f94fb);
    }

    .bg-gradient-overdue {
        background: linear-gradient(to right, #ff9966, #ff5e62);
    }

    .bg-gradient-popular {
        background: linear-gradient(to right, #11998e, #38ef7d);
    }
</style>

<div class="container-fluid py-4">
    <h1 class="my-4">Chào mừng đến với Trang Quản trị</h1>
    <p class="lead text-muted">Tổng quan về các chức năng quản lý và thống kê hệ thống.</p>
    <hr class="mb-5" />

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="stat-card bg-gradient-staff shadow">
                <div class="stat-icon">
                    <i class="bi bi-person-video2"></i>
                </div>
                <h5 class="stat-card-title">Quản lý nhân viên</h5>
                <p class="stat-card-text">Quản lý các tài khoản Thủ thư.</p>
                <div class="stat-card-footer">
                    <a asp-action="ManageStaff">
                        Đi đến quản lý <i class="bi bi-arrow-right-circle-fill ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="stat-card bg-gradient-overdue shadow">
                <div class="stat-icon">
                    <i class="bi bi-calendar-x"></i>
                </div>
                <h5 class="stat-card-title">Sách trễ hạn</h5>
                <p class="stat-card-text">Xem độc giả và sách đang mượn quá hạn.</p>
                <div class="stat-card-footer">
                    <a asp-controller="Admin" asp-action="OverdueStatistics">
                        Xem thống kê <i class="bi bi-arrow-right-circle-fill ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="stat-card bg-gradient-popular shadow">
                <div class="stat-icon">
                    <i class="bi bi-trophy-fill"></i>
                </div>
                <h5 class="stat-card-title">Sách mượn nhiều</h5>
                <p class="stat-card-text">Top 10 sách được mượn nhiều nhất.</p>
                <div class="stat-card-footer">
                    <a asp-controller="Admin" asp-action="PopularBooks">
                        Xem thống kê <i class="bi bi-arrow-right-circle-fill ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>