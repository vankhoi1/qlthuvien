@model IEnumerable<QuanLyThuVien.Models.PopularBookViewModel>

@{
    ViewData["Title"] = "Thống kê Sách được mượn nhiều nhất";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .card-header-custom {
        background: linear-gradient(to right, #434343, #212529);
        color: white;
    }

    .rank-badge {
        font-size: 1.5rem;
        line-height: 1;
    }
</style>

<div class="container-fluid py-4">
    <div class="card shadow-sm">
        <div class="card-header card-header-custom d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                <i class="bi bi-star-fill me-2"></i> @ViewData["Title"]
            </h4>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="popularBooksTable" class="table table-hover align-middle" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width: 5%;">Hạng</th>
                            <th>Tên sách</th>
                            <th>Tác giả</th>
                            <th class="text-center">Số lượt mượn</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rank = 1;
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center">Không có dữ liệu thống kê sách được mượn.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        @if (rank == 1)
                                        {
                                            <span class="rank-badge">🥇</span>
                                        }
                                        else if (rank == 2)
                                        {
                                            <span class="rank-badge">🥈</span>
                                        }
                                        else if (rank == 3)
                                        {
                                            <span class="rank-badge">🥉</span>
                                        }
                                        else
                                        {
                                            @rank
                                        }
                                    </td>
                                    <td>@item.Title</td>
                                    <td>@item.Author</td>
                                    <td class="text-center fw-bold">@item.LoanCount</td>
                                </tr>
                                rank++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-light d-flex justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle-fill me-1"></i> Về Dashboard
            </a>

            <form asp-action="ExportPopularToExcel" method="post" class="mb-0">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-file-earmark-excel-fill me-1"></i> Xuất Excel
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#popularBooksTable').DataTable({
                paging: false,
                lengthChange: false,
                info: false,
                "order": [[3, "desc"]],
                language: {
                    sZeroRecords: "Không có dữ liệu thống kê sách được mượn.",
                    sSearch: "Tìm kiếm:",
                },
                "columnDefs": [
                    { "orderable": false, "targets": 0 }
                ]
            });
        });
    </script>
}