@model QuanLyThuVien.Models.BookListViewModel
@{
    ViewData["Title"] = "Thư Viện Sách Online";
}

<style>
    /* Làm mờ trang lúc đầu để tạo hiệu ứng xuất hiện */
    body {
        opacity: 0;
        transition: opacity 0.3s ease-in-out;
    }

        body.body-visible {
            opacity: 1;
        }

    /* Các phần style khác của bạn */
    .title-gradient {
        background: linear-gradient(to right, #007bff, #00c6ff);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .filter-card-themed {
        background: linear-gradient(to right, #007bff, #0056b3);
        color: white;
        padding: 2rem;
        border-radius: 0.75rem;
    }

        .filter-card-themed .form-label {
            color: rgba(255, 255, 255, 0.8);
        }

    .book-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
        border-radius: 0.75rem;
    }

        .book-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15) !important;
        }

        .book-card .card-title {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

    .unavailable-card {
        opacity: 0.6;
        filter: grayscale(80%);
    }

    /* === CSS MỚI CHO HIỂN THỊ TÊN FILE VÀ XEM TRƯỚC === */
    #imageFileName {
        /* Đảm bảo tên file không bị co lại trên màn hình nhỏ */
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        cursor: default; /* Trông giống text hơn là input */
    }

    #imagePreviewContainer {
        border: 2px dashed #ddd;
        border-radius: 0.5rem;
        padding: 0.5rem;
        background-color: #f8f9fa;
        max-width: 250px; /* Giới hạn kích thước vùng xem trước */
    }
</style>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold title-gradient">Thư Viện Sách Online</h1>
        <p class="lead text-muted">Khám phá tri thức, kết nối đam mê đọc sách</p>
    </div>

    <div class="card shadow-sm mb-4 filter-card-themed">
        <h5 class="mb-3 fw-bold"><i class="bi bi-funnel-fill me-2"></i>Bộ lọc tìm kiếm</h5>
        <form id="textSearchForm" asp-action="Index" asp-controller="Home" method="get" class="row g-3 align-items-end">
            <div class="col-lg-5 col-md-12">
                <label class="form-label">Tìm kiếm</label>
                <input name="searchString" class="form-control" placeholder="Nhập tiêu đề hoặc tác giả..." value="@ViewData["SearchString"]" />
            </div>
            <div class="col-lg-3 col-md-6">
                <label class="form-label">Thể loại</label>
                <select name="genre" class="form-select" asp-items="@(new SelectList(ViewBag.Genres, ViewData["Genre"]?.ToString()))">
                    <option value="">Tất cả thể loại</option>
                </select>
            </div>
            <div class="col-lg-2 col-md-6">
                <label class="form-label">Trạng thái</label>
                <select name="filter" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="available" selected="@(ViewData["Filter"]?.ToString() == "available")">Có sẵn</option>
                    <option value="borrowed" selected="@(ViewData["Filter"]?.ToString() == "borrowed")">Hết sách</option>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <option value="mybooks" selected="@(ViewData["Filter"]?.ToString() == "mybooks")">Đang mượn</option>
                    }
                </select>
            </div>
            <div class="col-lg-2 col-md-12">
                <button type="submit" class="btn btn-light w-100 fw-bold">
                    <i class="bi bi-search me-2"></i>Tìm kiếm
                </button>
            </div>
        </form>
    </div>

    <div class="card shadow-sm p-4 mb-5">
        <form id="imageSearchForm" asp-action="SearchByImage" asp-controller="Home" method="post" enctype="multipart/form-data">

            <label for="imageFile" class="form-label fw-bold"><i class="bi bi-camera-fill me-2"></i>Tìm bằng hình ảnh:</label>

            <div class="input-group">
                <input type="file" name="imageFile" id="imageFile" class="d-none" accept="image/*" required>

                <button type="button" id="customImageButton" class="btn btn-outline-primary">
                    <i class="bi bi-folder-plus me-2"></i> Chọn ảnh...
                </button>

                <span id="imageFileName" class="form-control text-muted">Chưa có ảnh nào được chọn</span>

                <button type="submit" class="btn btn-success">
                    <i class="bi bi-search me-2"></i>Tìm
                </button>
            </div>

            <div id="imagePreviewContainer" class="mt-3" style="display: none;">
                <h6 class="text-muted small">Xem trước ảnh:</h6>
                <img id="imagePreview" src="#" alt="Xem trước ảnh" class="img-thumbnail" style="max-height: 200px; max-width: 200px; object-fit: cover;" />
            </div>
        </form>
    </div>
    <hr />

    <div id="ket-qua-tim-kiem" class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model != null && Model.Books.Any())
        {
            @foreach (var book in Model.Books)
            {
                <div class="col">
                    @{
                        var cardClass = book.SoLuong > 0 ? "" : "unavailable-card";
                    }
                    <div class="card h-100 shadow-sm book-card @cardClass">
                        <div class="position-relative">
                            @{
                                var imageUrl = !string.IsNullOrEmpty(book.CoverImagePath)
                                ? Url.Content(book.CoverImagePath)
                                : Url.Content("~/images/no-image.jpg");
                            }
                            <a asp-action="BookDetails" asp-controller="Account" asp-route-bookId="@book.BookId">
                                <img src="@imageUrl" class="card-img-top" alt="Ảnh sách: @book.Title" style="height: 300px; object-fit: cover;" />
                            </a>
                            @if (book.SoLuong > 0)
                            {
                                <span class="badge bg-success position-absolute top-0 end-0 m-2 shadow-sm">Có sẵn</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary position-absolute top-0 end-0 m-2 shadow-sm">Hết sách</span>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title fw-bold" title="@book.Title">@book.Title</h6>
                            <p class="card-text text-muted small flex-grow-1">Tác giả: @book.Author</p>
                        </div>
                        <div class="card-footer bg-transparent border-0 d-flex justify-content-between align-items-center">
                            <a asp-action="BookDetails" asp-controller="Account" asp-route-bookId="@book.BookId" class="btn btn-outline-primary btn-sm">Chi Tiết</a>

                            @if (User.Identity.IsAuthenticated)
                            {
                                if (Model.BorrowedBookIds.Contains(book.BookId))
                                {
                                    <button class="btn btn-success btn-sm" disabled>Đang Mượn</button>
                                }
                                else if (Model.PendingLoanBookIds.Contains(book.BookId))
                                {
                                    <button class="btn btn-secondary btn-sm" disabled>Chờ duyệt</button>
                                }
                                else if (Model.ReservedBookIds.Contains(book.BookId))
                                {
                                    <button class="btn btn-info btn-sm" disabled>Đã đặt trước</button>
                                }
                                else if (book.IsAvailable)
                                {
                                    <form class="action-form"
                                          data-action-type="mượn"
                                          data-book-title="@book.Title"
                                          asp-action="BorrowBook"
                                          asp-controller="Account"
                                          method="post">
                                        <input type="hidden" name="bookId" value="@book.BookId" />
                                        <button type="submit" class="btn btn-primary btn-sm">Mượn Sách</button>
                                    </form>
                                }
                                else
                                {
                                    <form class="action-form"
                                          data-action-type="đặt trước"
                                          data-book-title="@book.Title"
                                          asp-action="ReserveBook"
                                          asp-controller="Account"
                                          method="post">
                                        <input type="hidden" name="bookId" value="@book.BookId" />
                                        <button type="submit" class="btn btn-warning btn-sm">Đặt Trước</button>
                                    </form>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-search fs-1 text-muted"></i>
                <p class="text-muted fs-5 mt-3">Không tìm thấy sách nào phù hợp.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // --- LOGIC CHỐNG CUỘN TRANG (Giữ nguyên) ---
            const scrollPosition = sessionStorage.getItem('scrollPosition');
            if (scrollPosition) {
                window.scrollTo(0, parseInt(scrollPosition, 10));
                sessionStorage.removeItem('scrollPosition');
            }
            document.body.classList.add('body-visible');

            const textSearchForm = document.getElementById('textSearchForm');
            const imageSearchForm = document.getElementById('imageSearchForm');
            function saveScrollPosition() {
                sessionStorage.setItem('scrollPosition', window.scrollY);
            }
            if(textSearchForm) {
                textSearchForm.addEventListener('submit', saveScrollPosition);
            }
            if(imageSearchForm) {
                imageSearchForm.addEventListener('submit', saveScrollPosition);
            }

            // --- Script cho SweetAlert2 (Giữ nguyên) ---
            const actionForms = document.querySelectorAll('.action-form');
            actionForms.forEach(form => {
                form.addEventListener('submit', function (event) {
                    event.preventDefault();
                    // ... (Code SweetAlert của bạn) ...
                    const actionType = form.dataset.actionType;
                    const bookTitle = form.dataset.bookTitle;
                    Swal.fire({
                        title: 'Bạn chắc chắn?',
                        text: `Bạn có muốn ${actionType} cuốn sách "${bookTitle}" không?`,
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#3085d6',
                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Đồng ý',
                        cancelButtonText: 'Hủy bỏ'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            form.submit();
                        }
                    });
                });
            });


            // === BẮT ĐẦU SCRIPT MỚI CHO TÌM KIẾM HÌNH ẢNH ĐẸP HƠN ===

            const imageFile = document.getElementById('imageFile');
            const customImageButton = document.getElementById('customImageButton');
            const imageFileName = document.getElementById('imageFileName');
            const imagePreviewContainer = document.getElementById('imagePreviewContainer');
            const imagePreview = document.getElementById('imagePreview');

            if (customImageButton) {
                // 1. Khi bấm vào nút "Chọn ảnh" giả
                customImageButton.addEventListener('click', function() {
                    imageFile.click(); // Kích hoạt input file thật
                });
            }

            if (imageFile) {
                // 2. Khi người dùng đã chọn file
                imageFile.addEventListener('change', function(e) {
                    const file = e.target.files[0];
                    if (file) {
                        // Hiển thị tên file
                        imageFileName.textContent = file.name;
                        imageFileName.classList.remove('text-muted');

                        // Đọc file và hiển thị ảnh xem trước
                        const reader = new FileReader();
                        reader.onload = function(event) {
                            imagePreview.src = event.target.result;
                            imagePreviewContainer.style.display = 'block'; // Hiển thị vùng xem trước
                        }
                        reader.readAsDataURL(file);
                    } else {
                        // Reset nếu người dùng bấm "Cancel"
                        imageFileName.textContent = 'Chưa có ảnh nào được chọn';
                        imageFileName.classList.add('text-muted');
                        imagePreview.src = '#';
                        imagePreviewContainer.style.display = 'none'; // Ẩn vùng xem trước
                    }
                });
            }
            // === KẾT THÚC SCRIPT MỚI ===

        });
    </script>
}