@* Giả sử bạn có một CreateLoanViewModel với các thuộc tính:
    public string Username { get; set; }
    public int BookId { get; set; }
*@
@model QuanLyThuVien.Models.CreateLoanViewModel

@{
    ViewData["Title"] = "Tạo Lượt mượn mới";
}

<h2>@ViewData["Title"]</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="CreateLoan" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Username" class="control-label">Tên người dùng (Độc giả)</label>
                @* Trong thực tế, đây nên là một ô tìm kiếm hoặc dropdown *@
                <input asp-for="Username" class="form-control" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="BookId" class="control-label">ID Sách</label>
                @* Đây cũng nên là một ô tìm kiếm hoặc dropdown các sách có sẵn *@
                <input asp-for="BookId" class="form-control" type="number" />
                <span asp-validation-for="BookId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Tạo lượt mượn" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>