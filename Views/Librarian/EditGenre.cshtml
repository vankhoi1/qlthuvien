@model QuanLyThuVien.Models.Genre

@{
    ViewData["Title"] = "Chỉnh sửa Thể loại";
}

<style>
    .form-container {
        max-width: 600px;
        margin: 2rem auto;
        padding: 2.5rem;
        background-color: #ffffff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        border: 1px solid #e9ecef;
    }

    .form-title {
        font-weight: 700;
        margin-bottom: 2rem;
        color: #343a40;
    }
</style>

<div class="form-container">
    <div class="text-center">
        <h2 class="form-title">Chỉnh sửa Thể loại</h2>
    </div>

    @if (ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger">
            <strong>Vui lòng sửa các lỗi sau:</strong>
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form id="editGenreForm" asp-action="EditGenre" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="GenreId" />

        <div class="mb-4">
            <label asp-for="Name" class="form-label">Tên Thể loại</label>
            <input asp-for="Name" class="form-control form-control-lg" placeholder="Ví dụ: Tiểu thuyết khoa học viễn tưởng" required autocomplete="off" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <a asp-action="ManageGenres" class="btn btn-outline-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary px-4">Lưu</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}