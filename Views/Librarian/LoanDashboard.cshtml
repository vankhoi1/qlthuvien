@model QuanLyThuVien.Models.LoanDashboardViewModel
@{
    ViewData["Title"] = "Tổng quan Mượn/Trả sách";
}

<style>
    .card-header-custom {
        background: linear-gradient(to right, #007bff, #0056b3);
        color: white;
    }

    .btn-action {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none;
        color: white !important;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

    .btn-action-approve {
        background-color: #198754;
    }
    /* Xanh lá */
    .btn-action-reject {
        background-color: #dc3545;
    }
    /* Đỏ */
    .btn-action-return {
        background-color: #0dcaf0;
    }
    /* Xanh ngọc */

    .badge-overdue {
        background-color: #dc3545 !important;
    }
    /* Đỏ */
    .badge-ontime {
        background-color: #0d6efd !important;
    }
    /* Xanh dương */

</style>

<div class="container-fluid">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header card-header-custom">
            <h5 class="mb-0"><i class="bi bi-envelope-paper-fill me-2"></i> Yêu Cầu Mượn Sách Chờ Duyệt</h5>
        </div>
        <div class="card-body">
            @if (Model.PendingLoans != null && Model.PendingLoans.Any())
            {
                <table id="pendingLoansTable" class="table table-striped table-hover align-middle" style="width:100%">
                    <thead>
                        <tr>
                            <th>Sách</th>
                            <th>Người mượn</th>
                            <th>Ngày yêu cầu</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var loan in Model.PendingLoans)
                        {
                            <tr>
                                <td>@loan.Book.Title</td>
                                <td>@loan.Username</td>
                                <td>@loan.BorrowDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-center">
                                    <form asp-action="ApproveLoan" method="post" class="d-inline">
                                        <input type="hidden" name="loanId" value="@loan.LoanId" />
                                        <button type="submit" class="btn btn-sm btn-action btn-action-approve">Duyệt</button>
                                    </form>
                                    <form asp-action="RejectLoan" method="post" class="d-inline">
                                        <input type="hidden" name="loanId" value="@loan.LoanId" />
                                        <button type="submit" class="btn btn-sm btn-action btn-action-reject">Từ chối</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted fst-italic">Không có yêu cầu mượn sách nào đang chờ xử lý.</p>
            }
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header card-header-custom">
            <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i> Yêu Cầu Gia Hạn Sách</h5>
        </div>
        <div class="card-body">
            @if (Model.ExtensionRequests != null && Model.ExtensionRequests.Any())
            {
                <table id="extensionRequestsTable" class="table table-striped table-hover align-middle" style="width:100%">
                    <thead>
                        <tr>
                            <th>Tên sách</th>
                            <th>Người mượn</th>
                            <th>Ngày yêu cầu</th>
                            <th>Hạn trả hiện tại</th>
                            <th>Hạn trả mới (dự kiến)</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in Model.ExtensionRequests)
                        {
                            <tr>
                                <td>@req.BookTitle</td>
                                <td>@req.Username</td>
                                <td>@req.RequestDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@(req.DueDate?.ToString("dd/MM/yyyy"))</td>
                                <td><strong>@(req.NewDueDate?.ToString("dd/MM/yyyy"))</strong></td>
                                <td class="text-center">
                                    <form asp-action="ApproveExtension" method="post" class="d-inline">
                                        <input type="hidden" name="notificationId" value="@req.NotificationId" />
                                        <button type="submit" class="btn btn-sm btn-action btn-action-approve">Duyệt</button>
                                    </form>
                                    <form asp-action="RejectExtension" method="post" class="d-inline">
                                        <input type="hidden" name="notificationId" value="@req.NotificationId" />
                                        <button type="submit" class="btn btn-sm btn-action btn-action-reject">Từ chối</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted fst-italic">Không có yêu cầu gia hạn nào đang chờ xử lý.</p>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header card-header-custom">
            <h5 class="mb-0"><i class="bi bi-journal-check me-2"></i> Sách Đang Được Mượn</h5>
        </div>
        <div class="card-body">
            @if (Model.ActiveLoans != null && Model.ActiveLoans.Any())
            {
                <table id="activeLoansTable" class="table table-striped table-hover align-middle" style="width:100%">
                    <thead>
                        <tr>
                            <th>Sách</th>
                            <th>Người mượn</th>
                            <th>Ngày mượn</th>
                            <th>Hạn trả</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var loan in Model.ActiveLoans)
                        {
                            <tr>
                                <td>@loan.Book.Title</td>
                                <td>@loan.Username</td>
                                <td>@loan.BorrowDate.ToString("dd/MM/yyyy")</td>
                                <td>@(loan.DueDate.HasValue ? loan.DueDate.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                                <td class="text-center">
                                    <span class="badge @(loan.DueDate <= DateTime.Now ? "badge-overdue" : "badge-ontime")">
                                        @(loan.DueDate <= DateTime.Now ? "Quá hạn" : "Đúng hạn")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <form asp-action="ReturnBook" method="post" class="d-inline">
                                        <input type="hidden" name="loanId" value="@loan.LoanId" />
                                        <button type="submit" class="btn btn-sm btn-action btn-action-return">Xử lý trả sách</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted fst-italic">Không có sách nào đang được mượn.</p>
            }
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="Librarian" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left-circle-fill me-1"></i> Quay về Bảng điều khiển
        </a>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Việt hóa chung cho tất cả các bảng
            const languageConfig = {
                sProcessing: "Đang xử lý...",
                sLengthMenu: "Xem _MENU_ mục",
                sZeroRecords: "Không tìm thấy dòng nào phù hợp",
                sInfo: "Đang xem _START_ đến _END_ trong tổng số _TOTAL_ mục",
                sInfoEmpty: "Đang xem 0 đến 0 trong tổng số 0 mục",
                sInfoFiltered: "(được lọc từ _MAX_ mục)",
                sSearch: "Tìm kiếm:",
                oPaginate: {
                    sFirst: "Đầu",
                    sPrevious: "Trước",
                    sNext: "Tiếp",
                    sLast: "Cuối"
                }
            };

            // Khởi tạo DataTables cho cả 3 bảng
            $('#pendingLoansTable').DataTable({ language: languageConfig });
            $('#activeLoansTable').DataTable({ language: languageConfig });
            $('#extensionRequestsTable').DataTable({ language: languageConfig });
        });
    </script>
}