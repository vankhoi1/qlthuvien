@model List<QuanLyThuVien.Models.Genre>
@{
    ViewData["Title"] = "Quản lý Thể loại";
}

<style>
    .card-header-custom {
        background: linear-gradient(to right, #007bff, #0056b3);
        color: white;
    }

    .btn-action {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none;
        color: white !important; /* Đảm bảo chữ luôn màu trắng */
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

    .btn-action-edit {
        background-color: #0dcaf0; /* Xanh ngọc */
    }

    .btn-action-delete {
        background-color: #dc3545; /* Đỏ */
    }
</style>

<div class="card shadow-sm">
    <div class="card-header card-header-custom d-flex justify-content-between align-items-center">
        <h4 class="mb-0">
            <i class="bi bi-tags-fill me-2"></i> @ViewData["Title"]
        </h4>
        <a asp-action="CreateGenre" class="btn btn-light">
            <i class="bi bi-plus-circle-fill me-1"></i> Thêm mới
        </a>
    </div>

    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <table id="genresTable" class="table table-striped table-hover">
            <thead>
                <tr>
                    <th style="width: 15%;">ID Thể loại</th>
                    <th>Tên Thể loại</th>
                    <th style="width: 20%;" class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var genre in Model)
                {
                    <tr>
                        <td>@genre.GenreId</td>
                        <td>@genre.Name</td>
                        <td class="text-center">
                            <a asp-action="EditGenre" asp-route-id="@genre.GenreId" class="btn btn-sm btn-action btn-action-edit" title="Sửa">
                                <i class="bi bi-pencil-fill"></i> Sửa
                            </a>
                            <a asp-action="DeleteGenre" asp-route-id="@genre.GenreId" class="btn btn-sm btn-action btn-action-delete" title="Xóa">
                                <i class="bi bi-trash3-fill"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-light">
        <a asp-controller="Librarian" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left-circle-fill me-1"></i> Quay về Bảng điều khiển
        </a>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#genresTable').DataTable({
                language: {
                    sProcessing: "Đang xử lý...",
                    sLengthMenu: "Xem _MENU_ mục",
                    sZeroRecords: "Không tìm thấy dòng nào phù hợp",
                    sInfo: "Đang xem _START_ đến _END_ trong tổng số _TOTAL_ mục",
                    sInfoEmpty: "Đang xem 0 đến 0 trong tổng số 0 mục",
                    sInfoFiltered: "(được lọc từ _MAX_ mục)",
                    sSearch: "Tìm kiếm:",
                    oPaginate: {
                        sFirst: "Đầu",
                        sPrevious: "Trước",
                        sNext: "Tiếp",
                        sLast: "Cuối"
                    }
                }
            });
        });
    </script>
}