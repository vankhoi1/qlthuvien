@model List<QuanLyThuVien.Models.BookReservation>

@{
    ViewData["Title"] = "Quản lý Đặt trước";
}

<style>
    .card-header-custom {
        background: linear-gradient(to right, #007bff, #0056b3);
        color: white;
    }

    .btn-action {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: none;
        color: white !important;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }

    .btn-action-reject {
        background-color: #dc3545; /* Đỏ */
    }
</style>

<div class="card shadow-sm">
    <div class="card-header card-header-custom">
        <h4 class="mb-0">
            <i class="bi bi-calendar2-check-fill me-2"></i> @ViewData["Title"]
        </h4>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <table id="reservationsTable" class="table table-striped table-hover align-middle" style="width:100%">
            <thead>
                <tr>
                    <th>Sách</th>
                    <th>Người dùng</th>
                    <th>Ngày đặt trước</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reservation in Model)
                {
                    <tr>
                        <td>@reservation.Book?.Title</td>
                        <td>@reservation.Username</td>
                        <td>@reservation.ReservationDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <form asp-action="RejectReservation" method="post" style="display:inline;">
                                <input type="hidden" name="reservationId" value="@reservation.ReservationId" />
                                <button type="submit" class="btn btn-sm btn-action btn-action-reject" onclick="return confirm('Bạn có chắc chắn muốn hủy yêu cầu đặt trước này?');">
                                    <i class="bi bi-x-lg"></i> Hủy
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-light">
        <a asp-controller="Librarian" asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left-circle-fill me-1"></i> Quay về Bảng điều khiển
        </a>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#reservationsTable').DataTable({
                language: {
                    sProcessing: "Đang xử lý...",
                    sLengthMenu: "Xem _MENU_ mục",
                    sZeroRecords: "Không tìm thấy yêu cầu nào phù hợp",
                    sInfo: "Đang xem _START_ đến _END_ trong tổng số _TOTAL_ mục",
                    sInfoEmpty: "Đang xem 0 đến 0 trong tổng số 0 mục",
                    sInfoFiltered: "(được lọc từ _MAX_ mục)",
                    sSearch: "Tìm kiếm:",
                    oPaginate: {
                        sFirst: "Đầu",
                        sPrevious: "Trước",
                        sNext: "Tiếp",
                        sLast: "Cuối"
                    }
                },
                "columnDefs": [
                    { "orderable": false, "targets": 3 } // Tắt sắp xếp cho cột Hành động
                ]
            });
        });
    </script>
}