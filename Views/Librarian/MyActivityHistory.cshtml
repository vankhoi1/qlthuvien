@model IEnumerable<QuanLyThuVien.Models.LibrarianActivity>

@{
    ViewData["Title"] = "Lịch sử hoạt động của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0"><i class="bi bi-clock-history me-2"></i> @ViewData["Title"]</h4>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info text-center">
                <p class="mb-0">Bạn chưa có hoạt động nào được ghi nhận.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table id="myHistoryTable" class="table table-bordered table-hover" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 20%;">Thời gian</th>
                            <th style="width: 25%;">Hành động</th>
                            <th>Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td data-order="@item.Timestamp.Ticks">@item.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>

                                <td>
                                    @{
                                        var action = item.Action ?? "";
                                        string badgeClass = "bg-secondary"; // Mặc định

                                        if (action.Contains("Duyệt") || action.Contains("Xác nhận"))
                                        {
                                            badgeClass = "bg-success";
                                        }
                                        else if (action.Contains("Từ chối") || action.Contains("Xóa"))
                                        {
                                            badgeClass = "bg-danger";
                                        }
                                        else if (action.Contains("Cập nhật") || action.Contains("gia hạn"))
                                        {
                                            badgeClass = "bg-warning text-dark";
                                        }
                                        else if (action.Contains("Thêm"))
                                        {
                                            badgeClass = "bg-info";
                                        }
                                    }
                                    <span class="badge @badgeClass">@action</span>
                                </td>
                                <td>@Html.DisplayFor(modelItem => item.Details)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="card-footer bg-light">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left-circle-fill me-1"></i> Quay lại Bảng điều khiển
        </a>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#myHistoryTable').DataTable({
                language: {
                    sProcessing: "Đang xử lý...",
                    sLengthMenu: "Xem _MENU_ mục",
                    sZeroRecords: "Không tìm thấy dữ liệu phù hợp",
                    sInfo: "Đang xem _START_ đến _END_ trong tổng số _TOTAL_ mục",
                    sInfoEmpty: "Đang xem 0 đến 0 trong tổng số 0 mục",
                    sInfoFiltered: "(được lọc từ _MAX_ mục)",
                    sSearch: "Tìm kiếm:",
                    oPaginate: {
                        sFirst: "Đầu",
                        sPrevious: "Trước",
                        sNext: "Tiếp",
                        sLast: "Cuối"
                    }
                },
                "order": [[0, "desc"]]
            });
        });
    </script>
}