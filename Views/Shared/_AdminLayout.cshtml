<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

    <style>
        body {
            display: flex;
            min-height: 100vh;
            flex-direction: column;
            background-color: #f8f9fa;
        }

        .main-container {
            display: flex;
            flex: 1;
        }

        .sidebar {
            width: 250px;
            background-color: #343a40;
            padding: 15px;
            color: white;
            transition: width 0.3s;
        }

            .sidebar a {
                color: rgba(255, 255, 255, 0.8);
                text-decoration: none;
                display: block;
                padding: 10px 15px;
                border-radius: 4px;
                transition: background-color 0.2s;
            }

                .sidebar a:hover, .sidebar a.active {
                    background-color: #495057;
                    color: white;
                }

            .sidebar .nav-header {
                font-weight: bold;
                color: #adb5bd;
                margin-top: 1rem;
                margin-bottom: 0.5rem;
                padding: 0 15px;
                font-size: 0.8rem;
                text-transform: uppercase;
            }

        .content-wrapper {
            flex-grow: 1;
            padding: 20px;
            background-color: #f8f9fa;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Admin" asp-action="Index">Admin Dashboard</a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="nav-link btn btn-link text-light"><i class="bi bi-box-arrow-right me-1"></i>Đăng xuất</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-container">
        <aside class="sidebar">
            <nav class="nav flex-column">
                <div class="nav-header">Quản lý</div>
                <a class="nav-link" asp-controller="Admin" asp-action="ManageStaff"><i class="bi bi-people-fill me-2"></i>Quản lý nhân viên</a>
                <div class="nav-header">Thống kê</div>
                <a class="nav-link" asp-controller="Admin" asp-action="OverdueStatistics"><i class="bi bi-calendar-x me-2"></i>Sách trễ hạn</a>
                <a class="nav-link" asp-controller="Admin" asp-action="PopularBooks"><i class="bi bi-bar-chart-line-fill me-2"></i>Sách mượn nhiều</a>
            </nav>
        </aside>
        <main role="main" class="content-wrapper">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
    <script src="https://cdn.datatables.net/plug-ins/1.10.21/sorting/datetime-moment.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>